-const STALE_BRANCH_THRESHOLD: Duration = Duration::from_secs(60 * 60);
+const STALE_BRANCH_THRESHOLD: Duration = Duration::from_hours(1);

 #[derive(Debug, Clone, PartialEq, Eq)]
 pub struct PolicyRule {
