Tighten OAuth credentials file to 0o600 on Unix

`runtime/src/oauth.rs::write_credentials_root` writes
`~/.claw/credentials.json` (containing access + refresh tokens) via
`fs::write` followed by `fs::rename`, with no `set_permissions` call. The
file inherits the process umask — typically world-readable on multi-user
Linux/macOS systems.

Set 0o600 on the temp file *before* the rename so the destination never
exists with default-umask perms (rename(2) preserves the inode and its
permission bits). Best-effort tighten the parent directory to 0o700 as well
— failure there is non-fatal because the per-file mode is the actual
guarantee.

Wrapped in `#[cfg(unix)]` since `PermissionsExt` is Unix-only. Windows uses
a different ACL model and is left unchanged here; a follow-up could add an
`icacls`-equivalent path via the `windows-acl` crate if needed.
---
diff --git a/rust/crates/runtime/src/oauth.rs b/rust/crates/runtime/src/oauth.rs
--- a/rust/crates/runtime/src/oauth.rs
+++ b/rust/crates/runtime/src/oauth.rs
@@ -368,13 +368,31 @@
     }
 }

 fn write_credentials_root(path: &PathBuf, root: &Map<String, Value>) -> io::Result<()> {
     if let Some(parent) = path.parent() {
         fs::create_dir_all(parent)?;
+        // Best-effort: tighten the config dir. Failure is non-fatal — the
+        // per-file 0600 below is the actual guarantee against multi-user
+        // snooping of OAuth tokens.
+        #[cfg(unix)]
+        {
+            use std::os::unix::fs::PermissionsExt;
+            let _ = fs::set_permissions(parent, fs::Permissions::from_mode(0o700));
+        }
     }
     let rendered = serde_json::to_string_pretty(&Value::Object(root.clone()))
         .map_err(|error| io::Error::new(io::ErrorKind::InvalidData, error))?;
     let temp_path = path.with_extension("json.tmp");
     fs::write(&temp_path, format!("{rendered}\n"))?;
+
+    // Restrict to owner read/write before publishing. The mode survives the
+    // rename because rename(2) preserves the inode and its permission bits,
+    // so the destination never exists with default-umask perms.
+    #[cfg(unix)]
+    {
+        use std::os::unix::fs::PermissionsExt;
+        fs::set_permissions(&temp_path, fs::Permissions::from_mode(0o600))?;
+    }
+
     fs::rename(temp_path, path)
 }
